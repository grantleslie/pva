<h2 class="mb-4">Inbound Emails</h2>

<table class="table table-striped table-hover">
  <thead>
    <tr>
      <th>Date</th>
      <th>Job</th>
      <th>From</th>
      <th>Body</th>
    </tr>
  </thead>

  <tbody>
    <% @emails.each do |email| %>
      <tr>
        <td>
          <%= email.received_at&.strftime("%Y-%m-%d %H:%M") %>
        </td>

        <td>
          <%= email.job&.name %>
        </td>

        <td>
          <%= email.from %>
        </td>

        <td>
          <%= link_to inbound_preview(email), inbound_email_path(email) %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>